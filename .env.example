# Copy this file to .env for local development and fill in real values.
# In Vercel/Netlify, set these in the project's Environment Variables settings instead.

# Primary Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: additional Gemini API keys for round-robin rotation (comma-separated)
# GEMINI_API_KEYS=key_one,key_two,key_three

# Optional: override which Gemini models to use (comma-separated, falls back to defaults)
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash

# Optional: your deployed site URL for the sitemap (e.g. https://edutalk.vercel.app)
# VITE_BASE_URL=https://your-domain.com
